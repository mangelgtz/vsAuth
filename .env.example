# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="mysql://auth_user:auth_password@localhost:3306/auth_db"

# JWT secrets (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=replace_with_a_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret_64_chars

# Google OAuth2 — Web client (used by the backend to verify id_tokens
# AND to handle the WebView /auth/google/callback flow).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000

# Comma-separated client IDs of the native mobile apps (Android / iOS).
# These are the audiences the backend accepts when verifying id_tokens
# sent from the Flutter app (google_sign_in plugin). The web client_id
# above is always accepted, no need to list it again here.
# Leave empty if you only use the WebView flow.
GOOGLE_MOBILE_CLIENT_IDS=
# Cookie option (true = send refresh token as httpOnly cookie, false = in body)
REFRESH_TOKEN_COOKIE=
